# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloudhost

# JWT (required - server will refuse to start without it)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption (AES-256-GCM key as 64 hex chars = 32 bytes, required)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# API
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dashboard
DASHBOARD_URL=http://localhost:3000

# Docker / Deployment
DOCKER_REGISTRY=ghcr.io/your-org
DOCKER_NETWORK=cloudhost

# Storage
STORAGE_PATH=./data/storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cloudhost-storage

# Realtime
REALTIME_PORT=4000

# SMTP (email - used by workflow email node)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@cloudhost.local

# Domains
BASE_DOMAIN=cloudhost.local

# DigitalOcean (required for VPS + Docker deployment provisioning)
DIGITALOCEAN_API_TOKEN=your-digitalocean-api-token
CLOUDHOST_INSTANCE_DOMAIN=cloudhost.app

# Neon (optional - auto-provisions Postgres databases via Neon API)
NEON_API_KEY=your-neon-api-key

# Cloudflare (optional - registers DNS records for deployments)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# Anthropic (required for AI workflow node)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Workflow service
WORKFLOW_PORT=4001
