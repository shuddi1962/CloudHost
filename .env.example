# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloudhost

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# API
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dashboard
DASHBOARD_URL=http://localhost:3000

# Docker / Deployment
DOCKER_REGISTRY=ghcr.io/your-org
DOCKER_NETWORK=cloudhost

# Storage
STORAGE_PATH=./data/storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cloudhost-storage

# Realtime
REALTIME_PORT=4000

# SMTP (email)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@cloudhost.local

# Domains
BASE_DOMAIN=cloudhost.local
